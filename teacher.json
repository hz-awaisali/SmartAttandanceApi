  "7_admin_assigns_class_to_teacher": {
    "method": "POST",
    "url": "/api/timetables",
    "auth_required": true,
    "headers": {
      "Authorization": "Bearer {admin_token}"
    },
    "description": "This is how a teacher actually gets a class to teach. Admin picks an existing batch_id, program_course_id, room_id, slot_id, and assigns teacher_id.",
    "request_body": {
      "batch_id": 1,
      "program_course_id": 2,
      "teacher_id": 9,
      "room_id": 1,
      "day": "Wednesday",
      "slot_id": 2
    },
    "success_response": {
      "status": 201,
      "body": {
        "message": "Timetable created",
        "data": {
          "id": 11,
          "batch_id": 1,
          "program_course_id": 2,
          "teacher_id": 9,
          "room_id": 1,
          "day": "Wednesday",
          "slot_id": 2,
          "batch": { "batch_name": "BSCS-2023-M", "semester": 3, "shift": "Morning" },
          "course": { "course_code": "CS102", "course_title": "Data Structures" },
          "teacher": { "name": "Sara Malik", "employee_no": "T-102" },
          "room": { "room_no": "Room-101" },
          "time_slot": { "start_time": "09:00", "end_time": "10:00" },
          "created_at": "..."
        }
      }
    },
    "error_response_conflict": {
      "status": 422,
      "body": {
        "message": "This teacher, room, or batch already has a class scheduled at this day and time slot."
      }
    },
    "after_this": "Once this timetable row exists, GET /api/dashboard/teacher and GET /api/teacher/schedule for Sara Malik (teacher_id 9) will immediately show this class with full department/program/batch/timing details."
  },

  "8_start_session": {
    "method": "POST",
    "url": "/api/sessions/{timetable}/start",
    "url_example": "/api/sessions/3/start",
    "auth_required": true,
    "headers": { "Authorization": "Bearer {teacher_token}" },
    "description": "Teacher starts attendance for one of their OWN scheduled classes (timetable id, not session id). Server auto-creates an 'absent' attendance row for every student in that batch, then notifies them to connect to the room's WiFi.",
    "request_body": null,
    "success_response": {
      "status": 201,
      "body": {
        "message": "Session started",
        "data": {
          "id": 14,
          "timetable_id": 3,
          "session_date": "2026-06-29",
          "start_time": "08:00:00",
          "end_time": "09:00:00",
          "status": "active",
          "present_count": 0,
          "absent_count": 8,
          "student_count": 8,
          "created_at": "2026-06-29T08:00:05.000000Z"
        }
      }
    },
    "error_response_not_owner": {
      "status": 403,
      "body": { "message": "This action is unauthorized." },
      "note": "Happens if you try to start a timetable that belongs to a different teacher (TimetablePolicy::start)."
    },
    "error_response_already_active": {
      "status": 409,
      "body": { "message": "A session for this class is already active today." }
    }
  },

  "9_end_session": {
    "method": "POST",
    "url": "/api/sessions/{session}/end",
    "url_example": "/api/sessions/14/end",
    "auth_required": true,
    "headers": { "Authorization": "Bearer {teacher_token}" },
    "description": "Ends an active session (session id from step 8's response, NOT the timetable id). Marks remaining students absent-notified and notifies the teacher with a present/absent summary.",
    "request_body": null,
    "success_response": {
      "status": 200,
      "body": {
        "message": "Session ended",
        "data": {
          "id": 14,
          "timetable_id": 3,
          "session_date": "2026-06-29",
          "start_time": "08:00:00",
          "end_time": "09:00:00",
          "status": "ended",
          "present_count": 5,
          "absent_count": 3,
          "student_count": 8,
          "created_at": "2026-06-29T08:00:05.000000Z"
        }
      }
    },
    "error_response_not_active": {
      "status": 409,
      "body": { "message": "This session is not active." }
    },
    "error_response_not_owner": {
      "status": 403,
      "body": { "message": "This action is unauthorized." }
    }
  },

