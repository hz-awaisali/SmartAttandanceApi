  "13_attendance_report": {
    "method": "GET",
    "url": "/api/attendance/report",
    "url_with_filters_example": "/api/attendance/report?batch_id=1&course_id=2&date=2026-06-29&per_page=15",
    "auth_required": true,
    "headers": { "Authorization": "Bearer {teacher_token}" },
    "description": "Paginated attendance history across all of the teacher's OWN sessions. All query params are optional filters.",
    "query_params": {
      "course_id": "nullable|integer|exists:program_courses,id",
      "batch_id": "nullable|integer|exists:batches,id",
      "date": "nullable|date (YYYY-MM-DD)",
      "per_page": "nullable|integer|min:1|max:100 (default 15)"
    },
    "success_response": {
      "status": 200,
      "body": {
        "message": "Success",
        "data": [
          {
            "id": 101,
            "session_id": 14,
            "student_id": 1,
            "wifi_mac_detected": "AA:BB:CC:00:01:01",
            "status": "present",
            "marked_at": "2026-06-29T08:02:11.000000Z",
            "student": {
              "id": 1,
              "registration_no": "CS-23-001",
              "name": "BSCS Student 1"
            },
            "session": {
              "id": 14,
              "session_date": "2026-06-29",
              "status": "ended",
              "timetable": {
                "course": { "course_code": "CS102", "course_title": "Data Structures" }
              }
            }
          }
        ]
      },
      "known_gap": "This list is paginated server-side (15 per page) but the response does not include pagination meta (current_page/last_page/total) — only the flat array of items is returned in 'data'."
    }
  },

