                  "code": "BSCS",
                  "department": {
                    "id": 1,
                    "name": "Computer Science"
                  }
                }
              },
              "teacher": {
                "id": 9,
                "user_id": 28,
                "department_id": null,
                "employee_no": "T-100",
                "designation": "Lecturer",
                "phone": "0300-1234567",
                "is_hod": false,
                "name": "Bilal Ahmed",
                "email": "bilal.ahmed2@university.edu",
                "status": "active"
              },
              "room": {
                "id": 1,
                "room_no": "Room-101",
                "wifi_name": "Lab-WiFi-101",
                "wifi_mac": "AA:BB:CC:00:01:01"
              },
              "time_slot": {
                "id": 1,
