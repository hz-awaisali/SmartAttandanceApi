  "5_teacher_full_schedule": {
    "method": "GET",
    "url": "/api/teacher/schedule",
    "auth_required": true,
    "headers": {
      "Authorization": "Bearer {teacher_token}"
    },
    "description": "New endpoint - returns the teacher's ENTIRE weekly timetable (every day, not just today), grouped by day.",
    "success_response": {
      "status": 200,
      "body": {
        "message": "Success",
        "data": {
          "Monday": [
            {
              "id": 3,
              "day": "Monday",
              "batch": { "batch_name": "BSCS-2023-M", "semester": 3, "shift": "Morning", "program": { "name": "BS Computer Science", "department": { "name": "Computer Science" } } },
              "course": { "course_code": "CS102", "course_title": "Data Structures" },
              "room": { "room_no": "Room-101" },
              "time_slot": { "start_time": "08:00", "end_time": "09:00" }
            }
          ],
          "Thursday": [
            {
              "id": 7,
              "day": "Thursday",
              "batch": { "batch_name": "BSCS-2023-M", "semester": 3, "shift": "Morning", "program": { "name": "BS Computer Science", "department": { "name": "Computer Science" } } },
              "course": { "course_code": "CS202", "course_title": "Computer Networks" },
              "room": { "room_no": "Room-102" },
              "time_slot": { "start_time": "09:00", "end_time": "10:00" }
            }
          ]
        }
      },
      "note": "Object is grouped by day name. A day with no class simply won't be a key in this object — empty object {} means no classes assigned at all yet."
    }
  },

