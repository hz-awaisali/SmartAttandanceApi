{
  "note": "Teacher-related API endpoints after the recent changes: (1) department_id is now optional when registering/creating a teacher, because one teacher can be assigned courses across multiple departments via the timetable instead of being locked to a single department; (2) teacher/student profile is auto-created on self-register; (3) dashboard + schedule responses now include full nested department/program/batch/timing info; (4) missing-profile crashes now return a clean 404 instead of a 500.",

  "1_register_teacher": {
    "method": "POST",
    "url": "/api/auth/register",
    "auth_required": false,
    "request_body": {
      "name": "Bilal Ahmed",
      "email": "bilal.ahmed2@university.edu",
      "password": "password123",
      "password_confirmation": "password123",
      "role": "teacher",
      "employee_no": "T-100",
      "designation": "Lecturer",
      "phone": "0300-1234567"
    },
    "request_notes": "department_id is NOT required for role=teacher anymore. You may still send it if you want to set a home department, but it can be omitted entirely.",
    "success_response": {
      "status": 201,
      "body": {
        "message": "Registration successful",
        "data": {
          "user": {
            "id": 28,
            "name": "Bilal Ahmed",
            "email": "bilal.ahmed2@university.edu",
            "role": "teacher",
            "status": "active",
            "created_at": "2026-06-29T08:10:00.000000Z"
          },
          "token": "14|nQwErTyUiOpAsDfGhJkLzXcVbNm1234567890"
        }
      }
    },
    "error_response_validation": {
      "status": 422,
      "body": {
        "message": "The employee no has already been taken.",
        "errors": {
          "employee_no": ["The employee no has already been taken."]
        }
      }
    }
  },

